# stamp environment - managed by secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3003
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
# Database role: gracon_stamp_app
# Generate this role password with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Deployment secret source: STAMP_DATABASE_URL
DATABASE_URL=postgresql://gracon_stamp_app:password@host/dbname?sslmode=require

# Shared user JWT
# Must match api/auth JWT_SECRET.
# Deployment secret source: PLATFORM_USER_JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Institution private-key encryption
# Must match api/institution INSTITUTION_ENCRYPTION_SECRET.
# Deployment secret source: INSTITUTION_PRIVATE_KEY_ENCRYPTION_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INSTITUTION_ENCRYPTION_SECRET=

# Signature private-key encryption
# Must match api/signature SIGNATURE_ENCRYPTION_SECRET.
# Deployment secret source: SIGNATURE_PRIVATE_KEY_ENCRYPTION_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SIGNATURE_ENCRYPTION_SECRET=

# Frontend and CORS
FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:4001,http://localhost:4002
