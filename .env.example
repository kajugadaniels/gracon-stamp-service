# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3003
APP_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT (shared with api/auth/) ──────────────────────────────────────────────
JWT_SECRET=same_secret_as_auth_service_here

# ─── Institution key decryption ───────────────────────────────────────────────
# Must match INSTITUTION_ENCRYPTION_SECRET in api/institution/
# The stamp service decrypts institution private keys to produce Signature 1
INSTITUTION_ENCRYPTION_SECRET=same_value_as_in_api_institution_service

# ─── Personal key decryption ──────────────────────────────────────────────────
# Must match SIGNATURE_ENCRYPTION_SECRET in api/signature/
# The stamp service decrypts the user's personal private key to produce Signature 2
SIGNATURE_ENCRYPTION_SECRET=same_value_as_in_api_signature_service

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Optional additional allowed origins, comma-separated.
# Add the admin app and the documents app so they can call the stamp API.
FRONTEND_URLS=http://localhost:4001,http://localhost:4002